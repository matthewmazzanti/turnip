{
  "runtime": { "user": "homelab" },

  "containers": { "out": {}, "quiet": {}, "svc": {} },

  "networks": {
    "lan": {
      "gateway": "10.0.0.1",
      "gateway_if": "gw0",
      "uplink": { "host_if": "vethW", "router_if": "vethRup", "link": "169.254.1.0", "nat": true },
      "attach": {
        "out":   { "ip": "10.0.0.11", "interface": "eth0", "egress": true },
        "quiet": { "ip": "10.0.0.12", "interface": "eth0" },
        "svc":   { "ip": "10.0.0.13", "interface": "eth0",
                   "ingress": [ { "proto": "tcp", "host_port": 8080, "port": 80 } ] }
      }
    }
  }
}
